rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive validators and security variables helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Match User Profiles (PII Restricted, strictly verified owners only)
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming()) 
        && incoming().keys().hasAll(['id', 'email', 'name', 'wishlist']) 
        && incoming().keys().size() == 4;
      
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming())
        && incoming().id == existing().id // id is immutable
        && incoming().email == existing().email // email is immutable
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'wishlist'])
        );
      
      allow delete: if isOwner(userId) && isValidId(userId);

      function isValidUserProfile(data) {
        return data.id is string && data.id.size() <= 128 && data.id == request.auth.uid
          && data.email is string && data.email.size() <= 256
          && data.name is string && data.name.size() <= 256
          && data.wishlist is list && data.wishlist.size() <= 100;
      }

      // Match orders placed under the specific authenticated customer account
      match /orders/{orderId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(orderId);
        allow list: if isOwner(userId) && isValidId(userId);
        
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(orderId) && isValidOrder(incoming())
          && incoming().keys().hasAll(['id', 'userId', 'items', 'subtotal', 'discount', 'shipping', 'total', 'shippingAddress', 'date', 'status'])
          && incoming().keys().size() == 10;
        
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(orderId) && isValidOrder(incoming())
          && incoming().id == existing().id
          && incoming().userId == existing().userId
          && incoming().total == existing().total
          && (
            incoming().diff(existing()).affectedKeys().hasOnly(['status'])
          );
        
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(orderId);

        function isValidOrder(data) {
          return data.id is string && data.id.size() <= 128
            && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
            && data.items is list && data.items.size() <= 50
            && data.subtotal is number && data.subtotal >= 0
            && data.discount is number && data.discount >= 0
            && data.shipping is number && data.shipping >= 0
            && data.total is number && data.total >= 0
            && data.shippingAddress is map
            && data.date is string && data.date.size() <= 128
            && data.status is string && (data.status == 'Processing' || data.status == 'Shipped' || data.status == 'Delivered');
        }
      }
    }
  }
}
